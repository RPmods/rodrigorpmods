{
  "name": "draft-simulator",
  "version": "3.4.6",
  "description": "STRINOVA Draft System + Gantigun Cup 2026 con motor de fases reconstruido, mapa previo independiente, picks simultáneos y asistencia privada entre compañeros.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.draftsimulator.app",
    "productName": "DraftSimulator",
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "DraftSimulator.exe"
    }
  }
}
