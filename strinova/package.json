{
  "name": "draft-simulator",
  "version": "3.2.25",
  "description": "STRINOVA Draft System con precarga silenciosa optimizada, video online desacoplado, bots de testing más estables, RPmods Services y animaciones modernas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.draftsimulator.app",
    "productName": "DraftSimulator",
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "DraftSimulator.exe"
    }
  }
}
